# GitHub API token for README generation.
# Optional for local runs, but strongly recommended to avoid rate limits.
GITHUB_TOKEN=

# Optional alias used by the app if GITHUB_TOKEN is not set.
GH_TOKEN=

# Token used by follow/block automation scripts.
# Prefer a classic PAT with user:follow, or a fine-grained token with Followers: write.
FOLLOW_BACK_TOKEN=

# Optional Telegram notification settings used by README and automation scripts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Shared automation flags.
# Accepted true values: 1, true, yes, on
# Default: false
DRY_RUN=false

# Whether bot accounts should be included in follow scripts.
# Default: false
INCLUDE_BOTS=false

# follow-stargazers.ts options
# Maximum number of accounts to follow in one run. Leave empty for no limit.
FOLLOW_LIMIT=

# Delay between follow requests in milliseconds.
# Default: 750
FOLLOW_DELAY_MS=750

# follow-back.ts options
# Maximum number of followers to follow back in one run. Leave empty for no limit.
FOLLOW_BACK_LIMIT=

# Delay between follow-back requests in milliseconds.
# Default: 750
FOLLOW_BACK_DELAY_MS=750

# block-spam-accounts.ts options
# Delay between block requests in milliseconds.
# Default: 750
BLOCK_DELAY_MS=750
